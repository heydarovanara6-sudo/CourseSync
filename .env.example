# Copy this file to .env and fill in real values before deploying.
# python-dotenv loads .env automatically — nothing else to configure.

# A long, random string used to sign session cookies. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Defaults to a local SQLite file under instance/ if not set.
# DATABASE_URL=sqlite:///coursesync.db

# Set to 1 for local development (enables debug mode + auto-reload).
FLASK_DEBUG=0

# Port the dev server listens on.
PORT=5000
